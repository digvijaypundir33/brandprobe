{
  "name": "brandprobe-init",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "dev:local": "NEXT_PUBLIC_SUPABASE_ENV=local next dev -p 3001",
    "dev:prod": "NEXT_PUBLIC_SUPABASE_ENV=production next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "clean": "rm -rf .next",
    "clean:build": "rm -rf .next && next build",
    "lint": "eslint",
    "test": "jest",
    "test:scraper": "jest scraper.test.ts --verbose",
    "test:ai": "jest ai.test.ts --verbose",
    "test:e2e": "jest e2e.test.ts --verbose",
    "test:url": "jest e2e.test.ts --verbose",
    "clear-reports": "npx tsx scripts/clear-reports.ts",
    "db:clear": "npx tsx scripts/clear-reports.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@paypal/paypal-js": "^9.4.0",
    "@paypal/paypal-server-sdk": "^2.2.0",
    "@paypal/react-paypal-js": "^9.0.1",
    "@sparticuz/chromium": "^143.0.4",
    "@supabase/supabase-js": "^2.98.0",
    "framer-motion": "^12.34.3",
    "groq-sdk": "^0.37.0",
    "jose": "^6.1.3",
    "lucide-react": "^0.576.0",
    "next": "16.1.6",
    "openai": "^6.25.0",
    "playwright": "^1.58.2",
    "playwright-core": "^1.58.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
