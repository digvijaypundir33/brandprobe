# BrandProbe Environment Variables
# Copy this file to .env.local and fill in your values

# ===================
# Supabase
# ===================
# Get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54331
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ===================
# AI Provider Configuration
# ===================
# Set which AI provider to use: anthropic | openai | groq
# If not set, will auto-detect based on available API keys
AI_PROVIDER=anthropic

# Anthropic (Claude) - https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key

# OpenAI (GPT-4) - https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key

# Groq (Llama 3.3) - https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key

# ===================
# Stripe
# ===================
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
NEXT_PUBLIC_STRIPE_PRICE_ID=price_your_price_id

# ===================
# Browserless (Web Scraping)
# ===================
# Get your API key from https://browserless.io/
BROWSERLESS_API_KEY=your_browserless_api_key

# ===================
# Resend (Email)
# ===================
# Get your API key from https://resend.com/
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=noreply@brandprobe.io

# ===================
# App Configuration
# ===================
NEXT_PUBLIC_APP_URL=http://localhost:3000
