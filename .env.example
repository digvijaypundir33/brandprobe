# BrandProbe Environment Variables
# Copy this file to .env.local and fill in your values

# ===================
# Supabase
# ===================
# Get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54331
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ===================
# AI Provider Configuration
# ===================
# Set which AI provider to use: anthropic | openai | groq
# If not set, will auto-detect based on available API keys
AI_PROVIDER=anthropic

# Anthropic (Claude) - https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key

# OpenAI (GPT-4) - https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key

# Groq (Llama 3.3) - https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key

# ===================
# Performance Tuning
# ===================
# Number of parallel API calls in legacy mode (when USE_CONSOLIDATED_PROMPTS=false)
# Recommended defaults:
#   - Ollama (local): 3 (balance between speed and memory usage)
#   - Cloud providers: 9 (can handle full parallelism)
# Valid range: 1-9 (max 9 since legacy mode has 9 API calls)
# AI_PARALLEL_CALLS=3

# Use consolidated prompts for faster analysis (2 calls instead of 9)
# Recommended: true for all providers (much faster)
# USE_CONSOLIDATED_PROMPTS=true

# ===================
# PayPal (Payment Method)
# ===================
# Get these from https://developer.paypal.com/dashboard/applications
# Mode: 'sandbox' for testing, 'production' for live
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your_paypal_client_id

# PayPal Product IDs (create these in PayPal dashboard)
# Starter: One-time $9 payment (not needed for orders)
# Pro: Subscription plan ID for $29/month
PAYPAL_PRO_PLAN_ID=P-xxxxxxxxxxxxxxxxxxxxx

# ===================
# Browserless (Web Scraping)
# ===================
# Get your API key from https://browserless.io/
BROWSERLESS_API_KEY=your_browserless_api_key

# ===================
# Resend (Email)
# ===================
# Get your API key from https://resend.com/
RESEND_API_KEY=re_your_resend_api_key
FROM_EMAIL="BrandProbe <noreply@brandprobe.io>"

# ===================
# Authentication
# ===================
# JWT secret for session tokens (generate with: openssl rand -base64 32)
JWT_SECRET=your-secret-key-change-in-production

# ===================
# App Configuration
# ===================
NEXT_PUBLIC_APP_URL=http://localhost:3001
